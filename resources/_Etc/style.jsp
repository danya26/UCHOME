	$("div[class^=c-tab] ul li a").on("click", function() {
		$(this).parent().addClass("over")
		$cTabParent = $(this).closest("div");
		$("a", $cTabParent).not( $(this) ).parent().removeClass("over");
	});
	$("div[class^=b-tab] ul li a").on("click", function() {
		$(this).parent().addClass("over")
		$cTabParent = $(this).closest("div");
		$("a", $cTabParent).not( $(this) ).parent().removeClass("over");
	});
</script>
